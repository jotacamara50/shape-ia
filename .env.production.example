# IMPORTANTE: Configure estas variáveis no servidor de produção
# NÃO commite este arquivo com valores reais!

# OpenAI API Key
OPENAI_API_KEY=sk-proj-seu-token-aqui

# Mercado Pago - PRODUÇÃO (substitua pelos tokens de produção)
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-seu-public-key-producao
MP_ACCESS_TOKEN=APP_USR-seu-access-token-producao

# Mercado Pago - Assinatura Secreta do Webhook (COPIE do painel do MP)
# Cole a assinatura que aparece na tela de configuração do webhook
MP_WEBHOOK_SECRET=sua-assinatura-secreta-aqui

# Database
POSTGRES_PASSWORD=sua-senha-segura-aqui

# Product Price
NEXT_PUBLIC_PRODUCT_PRICE=27.90
